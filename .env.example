# === Gemini (필수) — 텍스트 생성 + AI 모델 이미지 생성 ===
GEMINI_API_KEY=             # Google AI Studio에서 발급
GEMINI_TEXT_MODEL=          # 기본값: gemini-2.5-flash
GEMINI_IMAGE_MODEL=         # 기본값: gemini-2.5-flash-image

# === Replicate (필수) — 배경 제거 (recraft-ai/recraft-remove-background) ===
REPLICATE_API_TOKEN=        # https://replicate.com/account/api-tokens ($0.01/건)

# === 인증 (배포 시 필수) ===
GOOGLE_CLIENT_ID=           # Google OAuth
GOOGLE_CLIENT_SECRET=       # Google OAuth
NEXTAUTH_SECRET=            # openssl rand -base64 32
NEXTAUTH_URL=               # 배포 URL (예: https://pagecraft.vercel.app)

# === 사용량 제한 관리자 (선택) ===
# ADMIN_EMAILS=              # 쉼표 구분 (예: a@gmail.com,b@gmail.com) — 무제한

# === 에러 모니터링 Sentry (선택) ===
# NEXT_PUBLIC_SENTRY_DSN=    # 클라이언트 에러
# SENTRY_DSN=                # 서버 에러

# === 개발용 ===
# SKIP_AUTH=true             # API 인증 + 사용량 제한 스킵
# NEXT_PUBLIC_SKIP_AUTH=true # 클라이언트 인증 체크 스킵
